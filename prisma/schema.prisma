generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Wine {
  id              String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name            String
  winery          String?
  wineryId        String?            @map("winery_id") @db.Uuid
  wineLineId      String?            @map("wine_line_id") @db.Uuid
  varietalId      String?            @map("varietal_id") @db.Uuid
  description     String?
  priceUnit       Decimal?           @map("price_unit") @db.Decimal(10, 2)
  priceBox        Decimal?           @map("price_box") @db.Decimal(10, 2)
  unitsPerBox     Int?               @map("units_per_box")
  imageUrl        String?            @map("image_url")
  discountId      String?            @map("discount_id") @db.Uuid
  discountPercent Int?               @map("discount_percent")
  featured        Boolean            @default(false)
  active          Boolean            @default(true)
  createdAt       DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime           @updatedAt @map("updated_at") @db.Timestamptz(6)
  discount        Discount?          @relation(fields: [discountId], references: [id], onDelete: SetNull)
  normalizedWinery Winery?           @relation(fields: [wineryId], references: [id], onDelete: SetNull)
  varietal        Varietal?          @relation(fields: [varietalId], references: [id], onDelete: SetNull)
  wineLine        WineLine?          @relation(fields: [wineLineId], references: [id], onDelete: SetNull)
  wineIntensities WineIntensity[]
  wineMoments     WineMoment[]
  wineTypes       WineTypeRelation[]

  @@index([active])
  @@index([discountId])
  @@index([name])
  @@index([varietalId])
  @@index([wineLineId])
  @@index([wineryId])
  @@map("wines")
}

model Discount {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String
  percent   Int
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  wines     Wine[]

  @@index([name])
  @@map("discounts")
}

model Winery {
  id        String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String     @unique
  createdAt DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime   @updatedAt @map("updated_at") @db.Timestamptz(6)
  wineLines WineLine[]
  wines     Wine[]

  @@map("wineries")
}

model WineLine {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String
  wineryId  String   @map("winery_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  winery    Winery   @relation(fields: [wineryId], references: [id], onDelete: Cascade)
  wines     Wine[]

  @@unique([wineryId, name])
  @@index([name])
  @@map("wine_lines")
}

model Varietal {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String   @unique
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  wines     Wine[]

  @@map("varietals")
}

model Moment {
  id          String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String       @unique
  wineMoments WineMoment[]

  @@map("moments")
}

model WineType {
  id        String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String             @unique
  wineTypes WineTypeRelation[]

  @@map("wine_types")
}

model Intensity {
  id              String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name            String          @unique
  wineIntensities WineIntensity[]

  @@map("intensities")
}

model WineMoment {
  wineId   String @map("wine_id") @db.Uuid
  momentId String @map("moment_id") @db.Uuid
  moment   Moment @relation(fields: [momentId], references: [id], onDelete: Cascade)
  wine     Wine   @relation(fields: [wineId], references: [id], onDelete: Cascade)

  @@id([wineId, momentId])
  @@index([momentId])
  @@map("wine_moments")
}

model WineTypeRelation {
  wineId   String   @map("wine_id") @db.Uuid
  typeId   String   @map("type_id") @db.Uuid
  wine     Wine     @relation(fields: [wineId], references: [id], onDelete: Cascade)
  wineType WineType @relation(fields: [typeId], references: [id], onDelete: Cascade)

  @@id([wineId, typeId])
  @@index([typeId])
  @@map("wine_types_relation")
}

model WineIntensity {
  wineId      String    @map("wine_id") @db.Uuid
  intensityId String    @map("intensity_id") @db.Uuid
  intensity   Intensity @relation(fields: [intensityId], references: [id], onDelete: Cascade)
  wine        Wine      @relation(fields: [wineId], references: [id], onDelete: Cascade)

  @@id([wineId, intensityId])
  @@index([intensityId])
  @@map("wine_intensity")
}
